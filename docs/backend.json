
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences for system authentication and authority.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "employeeNumber": { "type": "string", "description": "Unique identifier for the user (User ID)." },
        "notes": { "type": "string", "description": "General notes about the user." },
        "role": { "type": "string", "enum": ["Apprentice", "Mentor_Apprentice", "Certified_Mentor", "admin"], "description": "Membership status: Apprentice (Default), Mentor_Apprentice, Certified_Mentor, or admin." },
        "is_mentor_certified": { "type": "boolean", "default": false },
        "mentor_shield_issued_date": { "type": "string", "format": "date-time", "nullable": true },
        "price_lock_status": { "type": "boolean", "default": true },
        "contactId": { "type": "string" }
      }
    },
    "MentorReview": {
      "title": "Mentor Review",
      "description": "A mediation node for resolving community disputes regarding mentor guidance.",
      "type": "object",
      "properties": {
        "requester_id": { "type": "string" },
        "target_mentor_id": { "type": "string" },
        "dispute_description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"], "default": "pending" },
        "resolution_notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requester_id", "target_mentor_id", "dispute_description"]
    },
    "Contact": {
        "title": "Contact",
        "description": "The absolute Single Source of Truth for all identities (Clients, Workers, Suppliers, Leads).",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "birthDate": { "type": "string", "format": "date" },
            "businessName": { "type": "string" },
            "website": { "type": "string", "format": "uri" },
            "employeeNumber": { "type": "string", "description": "Unique identifier for company tracking (User ID / Worker ID)." },
            "industryCode": { "type": "string", "description": "NAICS or custom industry classification." },
            "craProgramAccountNumber": { "type": "string", "description": "Business Number (BN) for tax purposes." },
            "userId": { "type": "string", "description": "The creator of the record." },
            "folderId": { "type": "string", "description": "Determines the role: Client, Supplier, Worker, etc." },
            "documentFolderId": { "type": "string", "description": "The linked folder in the Document Manager for evidence." },
            "status": { "type": "string", "enum": ["Unscheduled Leads", "Scheduled Leads", "Completed Leads"], "description": "CRM pipeline status for prospects." },
            "keywords": { "type": "array", "items": { "type": "string" } },
            "sin": { "type": "string", "description": "Social Insurance Number (HR Encrypted)." },
            "workerType": { "type": "string", "enum": ["employee", "contractor"] },
            "payType": { "type": "string", "enum": ["hourly", "salary"] },
            "payRate": { "type": "number" },
            "streetAddress": { "type": "string" },
            "city": { "type": "string" },
            "provinceState": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": { "type": "string" },
            "businessPhone": { "type": "string" },
            "cellPhone": { "type": "string" },
            "homePhone": { "type": "string" },
            "primaryPhoneType": { "type": "string", "enum": ["businessPhone", "cellPhone", "homePhone"] },
            "hasContract": { "type": "boolean", "description": "HR Flag: Contract on file." },
            "specialNeeds": { "type": "string" },
            "notes": { "type": "string" }
        },
        "required": ["name", "userId", "folderId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Authority registry."
    },
    "/mentor_reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/MentorReview" },
      "description": "Mediation registry."
    }
  }
}
