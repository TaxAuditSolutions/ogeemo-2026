
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "employeeNumber": { "type": "string", "description": "Unique identifier for the user (User ID)." },
        "notes": { "type": "string", "description": "General notes about the user." },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer", "none"], "description": "User authority level: admin (Full), editor (Read/Edit), viewer (Read Only), none (No Access)." }
      }
    },
    "Contact": {
        "title": "Contact",
        "description": "Represents a contact, which can be a person or a business.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "birthDate": { "type": "string", "format": "date" },
            "businessName": { "type": "string" },
            "employeeNumber": { "type": "string", "description": "Unique identifier for the contact (User ID)." },
            "craProgramAccountNumber": { "type": "string" },
            "userId": { "type": "string" },
            "folderId": { "type": "string" },
            "status": { "type": "string", "enum": ["Unscheduled Leads", "Scheduled Leads", "Completed Leads"], "description": "CRM pipeline status for prospects." },
            "keywords": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "userId", "folderId"]
    },
    "ContactFolder": {
        "title": "Contact Folder",
        "description": "A folder to organize contacts.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "parentId": { "type": "string" },
            "userId": { "type": "string" },
            "isSystem": { "type": "boolean", "description": "Flag for protected system folders" }
        },
        "required": ["name", "userId"]
    },
    "InternalAccount": {
        "title": "Internal Account",
        "description": "Represents a bank account, credit card, or cash fund belonging to the business.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["Bank", "Credit Card", "Cash", "Other"] },
            "userId": { "type": "string" }
        },
        "required": ["name", "type", "userId"]
    },
    "Invoice": {
        "title": "Invoice",
        "description": "Represents an invoice for a client.",
        "type": "object",
        "properties": {
            "invoiceNumber": { "type": "string" },
            "businessNumber": { "type": "string" },
            "companyName": { "type": "string" },
            "contactId": { "type": "string" },
            "supplierId": { "type": "string", "description": "The ID of the supplier associated with this invoice." },
            "originalAmount": { "type": "number" },
            "amountPaid": { "type": "number" },
            "dueDate": { "type": "string", "format": "date-time" },
            "invoiceDate": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["outstanding", "paid", "partially_paid", "overdue"] },
            "notes": { "type": "string" },
            "taxType": { "type": "number" },
            "taxRate": { "type": "number" },
            "userId": { "type": "string" }
        },
        "required": ["invoiceNumber", "companyName", "contactId", "originalAmount", "amountPaid", "dueDate", "invoiceDate", "status", "userId"]
    },
    "IncomeTransaction": {
        "title": "Income Transaction",
        "description": "Records an income transaction.",
        "type": "object",
        "properties": {
            "date": { "type": "string", "format": "date" },
            "company": { "type": "string" },
            "description": { "type": "string" },
            "totalAmount": { "type": "number" },
            "incomeCategory": { "type": "string" },
            "depositedTo": { "type": "string", "description": "ID of the InternalAccount where funds were received." },
            "paymentMethod": { "type": "string" },
            "userId": { "type": "string" }
        },
        "required": ["date", "company", "totalAmount", "incomeCategory", "userId"]
    },
    "ExpenseTransaction": {
        "title": "Expense Transaction",
        "description": "Records an expense transaction.",
        "type": "object",
        "properties": {
            "date": { "type": "string", "format": "date" },
            "company": { "type": "string" },
            "description": { "type": "string" },
            "totalAmount": { "type": "number" },
            "category": { "type": "string" },
            "paidFrom": { "type": "string", "description": "ID of the InternalAccount used for payment." },
            "paymentMethod": { "type": "string" },
            "userId": { "type": "string" }
        },
        "required": ["date", "company", "totalAmount", "category", "userId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile data."
    },
    "/internalAccounts/{accountId}": {
        "schema": { "$ref": "#/entities/InternalAccount" },
        "description": "Collection of user-defined bank and cash accounts."
    },
    "/contacts/{contactId}": {
        "schema": { "$ref": "#/entities/Contact" },
        "description": "Collection of all contacts."
    },
    "/invoices/{invoiceId}": {
        "schema": { "$ref": "#/entities/Invoice" },
        "description": "Collection of all invoices."
    },
    "/incomeTransactions/{transactionId}": {
        "schema": { "$ref": "#/entities/IncomeTransaction" },
        "description": "Collection of all income transactions."
    },
    "/expenseTransactions/{transactionId}": {
        "schema": { "$ref": "#/entities/ExpenseTransaction" },
        "description": "Collection of all expense transactions."
    }
  }
}
