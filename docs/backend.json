
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences for system authentication and authority.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "employeeNumber": { "type": "string", "description": "Unique identifier for the user (User ID)." },
        "notes": { "type": "string", "description": "General notes about the user." },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer", "none"], "description": "User authority level: admin (Full), editor (Read/Edit), viewer (Read Only), none (No Access)." }
      }
    },
    "Contact": {
        "title": "Contact",
        "description": "The absolute Single Source of Truth for all identities (Clients, Workers, Suppliers, Leads).",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "birthDate": { "type": "string", "format": "date" },
            "businessName": { "type": "string" },
            "website": { "type": "string", "format": "uri" },
            "employeeNumber": { "type": "string", "description": "Unique identifier for company tracking (User ID / Worker ID)." },
            "industryCode": { "type": "string", "description": "NAICS or custom industry classification." },
            "craProgramAccountNumber": { "type": "string", "description": "Business Number (BN) for tax purposes." },
            "userId": { "type": "string", "description": "The creator of the record." },
            "folderId": { "type": "string", "description": "Determines the role: Client, Supplier, Worker, etc." },
            "documentFolderId": { "type": "string", "description": "The linked folder in the Document Manager for evidence." },
            "status": { "type": "string", "enum": ["Unscheduled Leads", "Scheduled Leads", "Completed Leads"], "description": "CRM pipeline status for prospects." },
            "keywords": { "type": "array", "items": { "type": "string" } },
            "sin": { "type": "string", "description": "Social Insurance Number (HR Encrypted)." },
            "workerType": { "type": "string", "enum": ["employee", "contractor"] },
            "payType": { "type": "string", "enum": ["hourly", "salary"] },
            "payRate": { "type": "number" },
            "streetAddress": { "type": "string" },
            "city": { "type": "string" },
            "provinceState": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": { "type": "string" },
            "businessPhone": { "type": "string" },
            "cellPhone": { "type": "string" },
            "homePhone": { "type": "string" },
            "primaryPhoneType": { "type": "string", "enum": ["businessPhone", "cellPhone", "homePhone"] },
            "hasContract": { "type": "boolean", "description": "HR Flag: Contract on file." },
            "specialNeeds": { "type": "string" },
            "notes": { "type": "string" }
        },
        "required": ["name", "userId", "folderId"]
    },
    "ContactFolder": {
        "title": "Contact Folder",
        "description": "Hierarchical organization for identities.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "parentId": { "type": "string" },
            "userId": { "type": "string" },
            "isSystem": { "type": "boolean", "description": "Flag for protected structural folders (Clients, Workers, etc.)" }
        },
        "required": ["name", "userId"]
    },
    "InternalAccount": {
        "title": "Internal Account",
        "description": "Represents a bank account, credit card, or cash fund belonging to the business.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["Bank", "Credit Card", "Cash", "Other"] },
            "userId": { "type": "string" }
        },
        "required": ["name", "type", "userId"]
    },
    "Invoice": {
        "title": "Invoice",
        "description": "Represents an invoice for a client.",
        "type": "object",
        "properties": {
            "invoiceNumber": { "type": "string" },
            "businessNumber": { "type": "string" },
            "companyName": { "type": "string" },
            "contactId": { "type": "string" },
            "supplierId": { "type": "string" },
            "originalAmount": { "type": "number" },
            "amountPaid": { "type": "number" },
            "dueDate": { "type": "string", "format": "date-time" },
            "invoiceDate": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["outstanding", "paid", "partially_paid", "overdue"] },
            "notes": { "type": "string" },
            "taxType": { "type": "string" },
            "userId": { "type": "string" }
        },
        "required": ["invoiceNumber", "companyName", "contactId", "originalAmount", "amountPaid", "dueDate", "invoiceDate", "status", "userId"]
    },
    "IncomeTransaction": {
        "title": "Income Transaction",
        "description": "Records an income transaction in the General Ledger.",
        "type": "object",
        "properties": {
            "date": { "type": "string", "format": "date" },
            "company": { "type": "string" },
            "description": { "type": "string" },
            "totalAmount": { "type": "number" },
            "incomeCategory": { "type": "string" },
            "depositedTo": { "type": "string" },
            "paymentMethod": { "type": "string" },
            "userId": { "type": "string" }
        },
        "required": ["date", "company", "totalAmount", "incomeCategory", "userId"]
    },
    "ExpenseTransaction": {
        "title": "Expense Transaction",
        "description": "Records an expense transaction in the General Ledger.",
        "type": "object",
        "properties": {
            "date": { "type": "string", "format": "date" },
            "company": { "type": "string" },
            "description": { "type": "string" },
            "totalAmount": { "type": "number" },
            "category": { "type": "string" },
            "paidFrom": { "type": "string" },
            "paymentMethod": { "type": "string" },
            "userId": { "type": "string" }
        },
        "required": ["date", "company", "totalAmount", "category", "userId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Authority registry."
    },
    "/contacts/{contactId}": {
        "schema": { "$ref": "#/entities/Contact" },
        "description": "Unified identity registry."
    },
    "/contactFolders/{folderId}": {
        "schema": { "$ref": "#/entities/ContactFolder" },
        "description": "Identity hierarchy."
    },
    "/invoices/{invoiceId}": {
        "schema": { "$ref": "#/entities/Invoice" },
        "description": "A/R records."
    },
    "/incomeTransactions/{transactionId}": {
        "schema": { "$ref": "#/entities/IncomeTransaction" },
        "description": "Income ledger."
    },
    "/expenseTransactions/{transactionId}": {
        "schema": { "$ref": "#/entities/ExpenseTransaction" },
        "description": "Expense ledger."
    }
  }
}
