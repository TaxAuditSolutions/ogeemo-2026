rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      // Safely retrieve user data. get() returns null if the document does not exist.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'admin';
    }

    function isEditor() {
      let data = getUserData();
      return isSignedIn() && data != null && (data.role == 'editor' || data.role == 'admin');
    }

    function isViewer() {
      let data = getUserData();
      return isSignedIn() && data != null && (data.role == 'viewer' || data.role == 'editor' || data.role == 'admin');
    }
    
    // Ownership check based on the 'userId' field common across data nodes
    function ownsDoc() {
      return isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }
    
    // Creation check to ensure user assigns themselves as the owner
    function assignsToSelf() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    match /contactFolders/{folderId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /contacts/{contactId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /clientAccounts/{accountId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /internalAccounts/{accountId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /invoices/{invoiceId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /invoiceLineItems/{itemId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /serviceItems/{itemId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /taxTypes/{typeId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /incomeTransactions/{transactionId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /expenseTransactions/{transactionId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /payableBills/{billId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /pettyCashTransactions/{transactionId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /payrollRuns/{runId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();

      match /details/{detailId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
      }
    }

    match /payrollRemittances/{remittanceId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /assets/{assetId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /equityTransactions/{transactionId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /companies/{companyId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /expenseCategories/{categoryId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /incomeCategories/{categoryId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /industries/{industryId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /loans/{loanId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /leads/{leadId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /projectTemplates/{templateId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /inventoryItems/{itemId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /inventoryLogs/{logId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }

    match /suppliers/{supplierId} {
      allow read: if ownsDoc() || isViewer();
      allow create: if assignsToSelf() || isEditor();
      allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /projects/{projectId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /tasks/{taskId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /ideas/{ideaId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /fileManagerFolders/{folderId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }

    match /files/{fileId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /crmActions/{actionId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }
    
    match /payrollWorkers/{workerId} {
        allow read: if ownsDoc() || isViewer();
        allow create: if assignsToSelf() || isEditor();
        allow update, delete: if ownsDoc() || isEditor();
    }

    match /leaveRequests/{leaveRequestId} {
      allow create: if assignsToSelfWorker() || isEditor();
      allow read: if ownsWorkerRequest() || isViewer();
      allow update: if ownsWorkerRequest() || isEditor();
      allow delete: if ownsWorkerRequest() || isEditor();
      
      function assignsToSelfWorker() {
        return isSignedIn() && request.resource.data.workerId == request.auth.uid;
      }
      function ownsWorkerRequest() {
        return isSignedIn() && resource.data.workerId == request.auth.uid;
      }
    }

    match /timeLogs/{timeLogId} {
      allow create: if assignsToSelfWorker() || isEditor();
      allow read: if ownsWorkerLog() || isViewer();
      allow update, delete: if ownsWorkerLog() || isEditor();
      
      function assignsToSelfWorker() {
        return isSignedIn() && request.resource.data.workerId == request.auth.uid;
      }
      function ownsWorkerLog() {
        return isSignedIn() && resource.data.workerId == request.auth.uid;
      }
      
      match /locations/{locationId} {
        allow read: if ownsWorkerLog() || isViewer();
        allow create: if assignsToSelfWorker() || isEditor();
      }
    }

    match /userActionChips/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /availableActionChips/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /trashedActionChips/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /accountingQuickNavItems/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /availableAccountingNavItems/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /hrQuickNavItems/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /availableHrNavItems/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /dialogSettings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /siteImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}