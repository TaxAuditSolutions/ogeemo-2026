
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files if they have the link, for seamless content viewing.
    // Only authenticated owners can write, update, or delete their own files.
    match /userFiles/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Site images are publically readable and were handled by a Cloud Function.
    // This functionality has been moved to a data URL scheme within Firestore,
    // so this storage rule is no longer necessary.
    // The path is left here as a comment for historical reference.
    // match /siteimages/{allPaths=**} {
    //   allow read;
    // }
  }
}
