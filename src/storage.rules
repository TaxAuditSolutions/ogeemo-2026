
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files if they have the link, for seamless content viewing.
    // Only authenticated owners can write, update, or delete their own files.
    match /userFiles/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for site-wide images in the /siteimages path.
    match /siteimages/{allPaths=**} {
      // Anyone can read public site images.
      allow read;
      
      // Only authenticated users can upload or delete images.
      // The actual logic is handled by a secured Cloud Function, but this
      // rule provides an additional layer of security.
      allow write: if request.auth != null;
    }
  }
}
