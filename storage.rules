rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files if they have the link, for seamless content viewing.
    // Only authenticated owners can write, update, or delete their own files.
    match /userFiles/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // New rule to allow authenticated users to write to the site-images folder.
    // Read is public to allow anyone to see the website images.
    match /site-images/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
