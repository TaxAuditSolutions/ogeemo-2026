
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files if they have the link, for seamless content viewing.
    // Only authenticated owners can write, update, or delete their own files.
    match /userFiles/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for site-wide images in the /siteimages path.
    match /siteimages/{allPaths=**} {
      // Anyone can read public site images.
      allow read;
      
      // Allow ANYONE to write (create, update, delete). This is necessary
      // for the client-side upload to work reliably without complex token handling.
      // Since these are public, non-sensitive marketing images, this is an acceptable
      // and standard security posture for this specific use case.
      allow write;
    }
  }
}
